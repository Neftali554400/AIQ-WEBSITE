# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Your live site URL (Netlify / custom domain) ────────────
SITE_URL=https://your-site.netlify.app

# ── JWT secret — generate a random 64-char string ───────────
# Run this to generate one:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# ── Gmail credentials for sending emails ────────────────────
# 1. Enable 2-Step Verification on your Google account
# 2. Go to myaccount.google.com → Security → App Passwords
# 3. Create an App Password for "Mail"
# 4. Paste the 16-character password below (no spaces)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASS=your-16-char-app-password
